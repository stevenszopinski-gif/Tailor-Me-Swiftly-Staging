{
    "manifest_version": 3,
    "name": "TailorMeSwiftly - Auto Job Capture",
    "version": "1.0.0",
    "description": "Capture job descriptions from any job board and auto-fill TailorMeSwiftly",
    "permissions": ["activeTab", "storage"],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Capture Job Description"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.linkedin.com/jobs/*",
                "*://*.indeed.com/*",
                "*://*.greenhouse.io/*",
                "*://*.lever.co/*",
                "*://*.glassdoor.com/*"
            ],
            "js": ["content.js"]
        }
    ]
}
